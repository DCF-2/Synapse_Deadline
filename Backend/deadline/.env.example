# ==========================================
# CONFIGURAÇÕES DO BACKEND (SPRING BOOT)
# ==========================================

# Chave secreta para assinar os tokens JWT.
# Em produção, deve ser uma string longa, complexa e imprevisível.
JWT_SECRET=your_jwt_secret_key_here_for_development_only

# Habilitar o console do banco H2 no navegador (true para dev, false para prod)
H2_CONSOLE_ENABLED=true

# (Opcional) Caso queira deixar o CORS dinâmico no futuro:
# CORS_ALLOWED_ORIGINS=http://localhost:5173,https://synapse-deadline.vercel.app
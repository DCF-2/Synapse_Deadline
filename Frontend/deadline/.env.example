# Backend API URL
VITE_API_URL=http://localhost:8080

# Cloudinary Configuration
# 1. Create a Cloudinary account at https://cloudinary.com
# 2. Copy your Cloud Name from the dashboard
# 3. Create an unsigned upload preset in Settings > Upload > Upload presets
#    - Set "Unsigned" mode
#    - No need for authentication
# 4. Add the values below:

VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=deadline_upload

# A chave do Google Maps fica no BACKEND (.env):
#   GOOGLE_MAPS_GEOCODING_API_KEY  — endereço → coordenadas
#   GOOGLE_MAPS_DISTANCE_API_KEY     — distância rodoviária
# O frontend usa navigator.geolocation do navegador — não precisa de chave aqui.
